# Arcology Environment Configuration
#
# In Docker, myapp.cfg is optional — all settings can be provided as environment
# variables (either here or in docker-compose.yml). Environment variables take
# precedence over myapp.cfg values when both are present.
#
# Generate required secrets:
#   python3 -c 'import secrets; print(f"SECRET_KEY={secrets.token_urlsafe(32)}")' >> .env
#   python3 -c 'import secrets; print(f"WORKER_API_KEY=wrk_{secrets.token_urlsafe(32)}")' >> .env
#
# SECRET_KEY: If not set, a random key is generated at startup (sessions won't persist across restarts).
#SECRET_KEY=
#
# WORKER_API_KEY: pre-shared key for worker authentication (must match on web and worker containers).
# Must be a long random string. Generate with:
#   python3 -c 'import secrets; print(f"wrk_{secrets.token_urlsafe(32)}")'
# If compromised: stop all workers, update this value on web and worker containers, restart.
# In-progress jobs will time out and be re-queued automatically.
#WORKER_API_KEY=
#
# Database URI (required in Docker if not using myapp.cfg):
#SQLALCHEMY_DATABASE_URI=postgresql://arcology_user:arcology_password@db/arcology

# Admin user creation (non-interactive, for Docker/CI)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme123!  # Must be at least 12 characters

# Archive extraction configuration
# Maximum nesting depth for recursive archive extraction (default: 10)
# Prevents infinite loops from self-referential archives (quines, trojans)
MAX_ARCHIVE_DEPTH=10

# Worker configuration (usually auto-configured in Docker)
# ARCOLOGY_API=http://web:5000/api   # API endpoint URL
# UPLOAD_DIR=/data/uploads            # Uploaded files directory
# OUTPUT_DIR=/data/outputs            # Analysis outputs directory
# POLL_INTERVAL=10                    # Max poll interval when worker is idle (seconds)
# LOG_LEVEL=INFO                      # Logging level: DEBUG, INFO, WARNING, ERROR
# TOOL_TIMEOUT=3600                   # Max seconds for subprocess execution and decompression

# Explicit-content moderation (NSFW classification)
# NSFW_ENABLED=true          # Set to false to disable NSFW_SCAN jobs entirely
# NSFW_MODEL_DIR=/opt/nsfw_models  # Directory containing model files (*.onnx + *_meta.json)
# NSFW_QUANTIZE=true         # Use INT8-quantized models (smaller/faster)
# NSFW_HIGH=0.90             # Stage-1 score >= HIGH → explicit immediately (no stage 2)
# NSFW_LOW=0.20              # Stage-1 score <= LOW  → not explicit immediately (no stage 2)
# NSFW_MIN_PIXELS=16384      # Skip images with total area (w×h) below this (default ≈ 128×128)
# NSFW_S2_THRESHOLD=0.70     # Stage-2 score required to convict (0.70 reduces false positives
#                            #   from stock/artistic photography vs the theoretical minimum 0.50)
# NSFW_S1_MIN_EXPLICIT=0.40  # Stage-1 must reach this for stage-2's explicit verdict to count;
#                            #   prevents overconfident stage-2 from overriding a sceptical stage-1

# S3-compatible object storage (enables distributed workers)
# Set STORAGE_BACKEND=s3 to use S3 instead of local filesystem.
# See docker-compose.s3.yml for a complete setup with Garage.
# STORAGE_BACKEND=local
# S3_ENDPOINT_URL=http://garage:3900
# S3_BUCKET=arcology
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=garage
# S3_PUBLIC_URL=http://localhost:3900  # Browser-reachable S3 URL (if different from S3_ENDPOINT_URL)
