# Arcology Environment Configuration
#
# In Docker, myapp.cfg is optional — all settings can be provided as environment
# variables (either here or in docker-compose.yml). Environment variables take
# precedence over myapp.cfg values when both are present.
#
# Generate required secrets:
#   python3 -c 'import secrets; print(f"SECRET_KEY={secrets.token_urlsafe(32)}")' >> .env
#   python3 -c 'import secrets; print(f"WORKER_API_KEY=wrk_{secrets.token_urlsafe(32)}")' >> .env
#
# SECRET_KEY: If not set, a random key is generated at startup (sessions won't persist across restarts).
#SECRET_KEY=
#
# WORKER_API_KEY: pre-shared key for worker authentication (must match on web and worker containers).
# Must be a long random string. Generate with:
#   python3 -c 'import secrets; print(f"wrk_{secrets.token_urlsafe(32)}")'
# If compromised: stop all workers, update this value on web and worker containers, restart.
# In-progress jobs will time out and be re-queued automatically.
#WORKER_API_KEY=
#
# Database URI (required in Docker if not using myapp.cfg):
#SQLALCHEMY_DATABASE_URI=postgresql://arcology_user:arcology_password@db/arcology

# Every setting documented in myapp/myapp.cfg.example can also be set here as an
# environment variable (so myapp.cfg is optional in Docker). Booleans accept
# 1/true/yes; integers and floats are parsed as numbers. Dict-valued settings
# are given as a JSON object — notably SQLALCHEMY_ENGINE_OPTIONS (connection
# pool tuning), e.g.:
#SQLALCHEMY_ENGINE_OPTIONS={"pool_size": 10, "max_overflow": 20, "pool_recycle": 1800, "pool_pre_ping": true}

# Number of Gunicorn worker processes for the web container (default 4).
# A common starting point is (2 * CPU cores) + 1.
#GUNICORN_WORKERS=4

# Threads per Gunicorn worker (default 8). The web container uses the threaded
# "gthread" worker class, so total request concurrency is workers * threads.
# Most requests are spent waiting on PostgreSQL, so threads absorb concurrent
# analysis-worker traffic cheaply. Raise it if you run many workers
# (e.g. docker compose up --scale worker=8) and see request timeouts.
#GUNICORN_THREADS=8

# Admin user creation (non-interactive, for Docker/CI)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme123!  # Must be at least 12 characters

# Public (anonymous) access
# PUBLIC_MODE=false          # Set true to allow anonymous read-only browsing
# PUBLIC_DOWNLOADS=true      # Set false to block anonymous file downloads (requires PUBLIC_MODE=true)

# Reverse proxy
# The app trusts one level of X-Forwarded-For/Proto/Host headers automatically.
# Your reverse proxy (nginx, Caddy, Traefik) must set these headers so that
# url_for(_external=True) and OIDC redirect URIs use the public hostname/scheme:
#   X-Forwarded-Host: your.public.domain
#   X-Forwarded-Proto: https

# SSO / OpenID Connect (optional)
# OIDC_ENABLED=false
# LOCAL_LOGIN_ENABLED=true
# OIDC_PROVIDER_NAME=Keycloak
# OIDC_DISCOVERY_URL=https://keycloak.example.com/realms/myrealm/.well-known/openid-configuration
# OIDC_CLIENT_ID=arcology
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email
# OIDC_MATCH_CLAIM=preferred_username
# OIDC_ROLE_ADMIN=arcology-admin
# OIDC_ROLE_READ_WRITE=arcology-read-write
# OIDC_ROLE_STAFF=arcology-staff
# OIDC_ROLE_READ_ONLY=arcology-read-only
# OIDC_ROLE_API_ACCESS=arcology-api
# OIDC_REQUIRE_ROLE=false
# OIDC_SINGLE_LOGOUT=false  # Set true only when the IdP realm is dedicated to Arcology
# OIDC_SYNC_INTERVAL=0      # Seconds between background permission re-checks (0=login-only)
# OIDC_AUTO_REDIRECT=true   # Redirect straight to SSO when LOCAL_LOGIN_ENABLED=false (skip login page)
# PERMANENT_SESSION_LIFETIME=28800

# Archive extraction configuration
# Maximum nesting depth for recursive archive extraction (default: 10)
# Prevents infinite loops from self-referential archives (quines, trojans)
MAX_ARCHIVE_DEPTH=10

# Ceiling on the assembled size of a chunked upload, in bytes (default: 16GB).
# The chunked upload path is the only way to exceed the per-request
# MAX_CONTENT_LENGTH; raise this for very large hard-disk images.
# MAX_UPLOAD_SIZE=17179869184

# Browser uploads at or above CHUNKED_UPLOAD_THRESHOLD bytes are uploaded in
# resumable chunks of CHUNKED_UPLOAD_CHUNK_SIZE bytes; smaller files use a normal
# form POST. CHUNK_SIZE must stay well below MAX_CONTENT_LENGTH (one request per
# chunk). Defaults: 100MB threshold, 50MB chunks.
# CHUNKED_UPLOAD_THRESHOLD=104857600
# CHUNKED_UPLOAD_CHUNK_SIZE=52428800

# Staging directory for in-progress chunked uploads (relative paths are resolved
# against the Flask instance path). An in-progress upload can be many gigabytes,
# so this MUST live on a persisted volume with adequate space — the default
# instance/.chunks sits on the container's ephemeral writable layer (potentially
# a small rootfs, or even tmpfs/RAM), and a container recreate would discard it.
# The bundled docker-compose.yml mounts ./data/chunks here by default.
# CHUNK_DIR=/app/instance/.chunks

# Asynchronous chunked-upload finalise (assemble + hash + store + ingest runs
# off the request thread; the client polls for the result). See
# doc/CHUNKED_UPLOADS.md. Defaults shown.
# FINALIZE_CONCURRENCY=2            # max concurrent finalises per web process
# FINALIZE_HEARTBEAT_SECONDS=15     # heartbeat cadence during assembly
# FINALIZE_STALE_SECONDS=120        # heartbeat age before an orphaned finalise is re-driven
# FINALIZE_RESULT_TTL_SECONDS=3600  # how long a done/failed session is kept for status polling

# Worker configuration (usually auto-configured in Docker)
# ARCOLOGY_API=http://web:5000/api   # API endpoint URL
# UPLOAD_DIR=/data/uploads            # Uploaded files directory
# OUTPUT_DIR=/data/outputs            # Analysis outputs directory
# POLL_INTERVAL=10                    # Ceiling of the idle poll backoff (seconds)
# POLL_BACKOFF_FLOOR=0.5              # Floor of the idle poll backoff (seconds)
# LOG_LEVEL=INFO                      # Logging level: DEBUG, INFO, WARNING, ERROR
# TOOL_TIMEOUT=3600                   # Max seconds for subprocess execution and decompression
# API_TIMEOUT=30                      # Worker -> web HTTP read timeout (seconds)

# Bounded worker HashDB steps (link / product recognition). The web app caps how
# long each such step may run server-side; the worker abandons the request after
# API_TIMEOUT. WORKER_STEP_DEADLINE_SECONDS MUST stay below API_TIMEOUT so the
# server can return a partial/retry result before the worker gives up. Both are
# plain env vars, so set them together here. Defaults: API_TIMEOUT=30,
# WORKER_STEP_DEADLINE_SECONDS=20.
# WORKER_STEP_DEADLINE_SECONDS=20

# Explicit-content moderation (NSFW classification)
# NSFW_ENABLED=true          # Set to false to disable NSFW_SCAN jobs entirely
# NSFW_MODEL_DIR=/opt/nsfw_models  # Directory containing model files (*.onnx + *_meta.json)
# NSFW_QUANTIZE=true         # Use INT8-quantized models (smaller/faster)
# NSFW_HIGH=0.90             # Stage-1 score >= HIGH → explicit immediately (no stage 2)
# NSFW_LOW=0.20              # Stage-1 score <= LOW  → not explicit immediately (no stage 2)
# NSFW_MIN_PIXELS=16384      # Skip images with total area (w×h) below this (default ≈ 128×128)
# NSFW_S2_THRESHOLD=0.70     # Stage-2 score required to convict (0.70 reduces false positives
#                            #   from stock/artistic photography vs the theoretical minimum 0.50)
# NSFW_S1_MIN_EXPLICIT=0.40  # Stage-1 must reach this for stage-2's explicit verdict to count;
#                            #   prevents overconfident stage-2 from overriding a sceptical stage-1
# NSFW_AGREE_THRESHOLD=0.55  # Both-models agreement path: if s1 and s2 both exceed this, convict
#                            #   regardless of the primary thresholds (catches moderate-confidence
#                            #   agreement that neither threshold alone would catch)
# NSFW_S1_STRONG=0.75        # Strong-s1 path: if s1 >= this and s2 > NSFW_LOW, convict;
#                            #   catches images where stage-1 is highly confident but stage-2
#                            #   only weakly corroborates (raise to be more conservative)

# S3-compatible object storage (enables distributed workers)
# Set STORAGE_BACKEND=s3 to use S3 instead of local filesystem.
# See docker-compose.s3.yml for a complete setup with Garage.
# STORAGE_BACKEND=local
# S3_ENDPOINT_URL=http://garage:3900
# S3_BUCKET=arcology
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=garage
# S3_PUBLIC_URL=http://localhost:3900  # Browser-reachable S3 URL (if different from S3_ENDPOINT_URL)

# Sentry error reporting and analytics. Set the DSN below.
# To disable, comment out SENTRY_DSN.
# SENTRY_DSN=https://KEYGOESHERE@o123456.ingest.de.sentry.io/123456
# Sample rate, default 1.0.
# SENTRY_TRACES_SAMPLE_RATE=1.0
# Profiling sample rate (fraction of *traced* transactions to profile),
# default 1.0. Profiling attaches a per-line CPU flame graph to each
# transaction - needed to tell DB wait apart from Python work.
# SENTRY_PROFILES_SAMPLE_RATE=1.0

# These allow the Sentry settings above to be overridden for the workers (only).
# Use these if you want to send worker analytics to a different DSN, or change the sample rate.
# SENTRY_WORKER_DSN=https://KEYGOESHERE@o123456.ingest.de.sentry.io/123456
# SENTRY_WORKER_TRACES_SAMPLE_RATE=1.0

