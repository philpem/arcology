#!/usr/bin/env python3
"""Run arco without installing — e.g. ``python cli/arco`` from the repo root."""

import os
import sys

# Ensure the cli/ directory is on sys.path so ``arccli`` is importable.
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from arccli.main import main

main()

