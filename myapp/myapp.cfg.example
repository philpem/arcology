# Debugging toggle - DO NOT enable this on production systems!
DEBUG = False

# Debugging -- database profiling. Creates a log file in /static/db_profile_report.html.
DEBUG_DB_PROFILING = False

# Debugging -- SQLAlchemy debug info
DEBUG_DB_LOG = False

# Cookie encryption key - this needs to be set uniquely for each installation
SECRET_KEY = "0123456789ABCDEF"

# Database connection string
# Example for SQLite (default)
#SQLALCHEMY_DATABASE_URI = "sqlite:////var/lib/myapp/arcology.db"
# Example for PostgreSQL
SQLALCHEMY_DATABASE_URI = "postgresql://arcology_user:arcology_password@db/arcology"

SQLALCHEMY_TRACK_MODIFICATIONS = False

# Connection pool tuning (defaults are set in app.py if not specified here).
# Increase pool_size when running many Gunicorn workers or heavy worker load.
#SQLALCHEMY_ENGINE_OPTIONS = {
#    'pool_size': 10,        # Persistent connections per worker process
#    'max_overflow': 20,     # Extra connections allowed under peak load
#    'pool_recycle': 1800,   # Recycle connections after 30 minutes
#    'pool_pre_ping': True,  # Verify connections are alive before using
#}

# =============================================================================
# Public (anonymous) access
# When PUBLIC_MODE is True, unauthenticated visitors can browse and search
# non-private items and artefacts without logging in.  All write actions
# (create, edit, delete, upload, share) remain login-gated.
# Private content is hidden from anonymous viewers as usual.
#
# PUBLIC_DOWNLOADS controls whether anonymous visitors may download artefact
# files.  Only takes effect when PUBLIC_MODE is True.  Default: True.
#
# Tier hierarchy (ascending privilege):
#   anonymous (PUBLIC_MODE) < READ_ONLY < READ_WRITE < STAFF < admin
# =============================================================================
#PUBLIC_MODE = False
#PUBLIC_DOWNLOADS = True

# =============================================================================
# Arcology-specific settings
# =============================================================================
UPLOAD_FOLDER = "uploads"           # Relative to instance folder, or absolute path
OUTPUT_FOLDER = "outputs"           # For analysis outputs (visualisations, etc.)
MAX_CONTENT_LENGTH = 4 * 1024 * 1024 * 1024  # 4GB max single-request upload
# Ceiling on the assembled size of a chunked upload (the CLI's large-file path,
# which is the only way to exceed MAX_CONTENT_LENGTH). Raise it for very large
# hard-disk images (e.g. 60-100GB); such images are best uploaded zstd-compressed.
MAX_UPLOAD_SIZE = 16 * 1024 * 1024 * 1024  # 16GB max assembled chunked upload
# Browser uploads at or above CHUNKED_UPLOAD_THRESHOLD bytes are sent in chunks
# of CHUNKED_UPLOAD_CHUNK_SIZE bytes (resumable, avoids the single-request limit);
# smaller files use a normal form POST. CHUNK_SIZE must stay well below
# MAX_CONTENT_LENGTH (each chunk is one request).
CHUNKED_UPLOAD_THRESHOLD = 100 * 1024 * 1024  # 100MB: chunk web uploads at/above this
CHUNKED_UPLOAD_CHUNK_SIZE = 50 * 1024 * 1024  # 50MB per chunk
# Staging directory for in-progress chunked uploads (relative paths resolve
# against the instance path; default <instance_path>/.chunks). An in-progress
# upload can be many gigabytes — point this at a persisted volume with adequate
# space. In Docker the default location is on the ephemeral container layer
# unless mounted (the bundled docker-compose.yml mounts ./data/chunks here).
# CHUNK_DIR = '/app/instance/.chunks'
# Asynchronous chunked-upload finalise (see doc/CHUNKED_UPLOADS.md). Defaults shown.
# FINALIZE_CONCURRENCY = 2            # max concurrent finalises per web process
# FINALIZE_HEARTBEAT_SECONDS = 15     # heartbeat cadence during assembly
# FINALIZE_STALE_SECONDS = 120        # heartbeat age before an orphaned finalise is re-driven
# FINALIZE_RESULT_TTL_SECONDS = 3600  # retain a done/failed session this long for status polling
ITEMS_PER_PAGE = 25
FILES_PER_PAGE = 100
ANALYSES_SHOWN = 5      # Max completed analyses shown per artefact before "Show All" appears

# Pre-shared key used by analysis workers.
# Generate: python3 -c 'import secrets; print(f"wrk_{secrets.token_urlsafe(32)}")'
# Must match the WORKER_API_KEY environment variable set on all worker containers.
WORKER_API_KEY = ""

# How long (in seconds) a job may stay in RUNNING state before it is considered
# stuck and eligible for reset back to PENDING.  Set this comfortably above the
# longest expected analysis run time.  Default: 3600 (1 hour).
STALE_JOB_TIMEOUT_SECONDS = 3600

# Maximum time (in seconds) a single worker-driven HashDB step may run on the
# server: the per-request PostgreSQL statement_timeout for recognition steps,
# and the wall-clock budget for link steps (which run many short statements and
# so cannot be bounded by statement_timeout alone).  This MUST stay below the
# worker's API read timeout (API_TIMEOUT, default 30s) — otherwise the worker
# abandons the request before the server can return a partial/retry result, and
# the step appears to fail.  Default: 20.  (Recognition steps additionally fail
# fast and let the worker retry a smaller batch; link steps return an advanced
# cursor so the worker just continues.)
WORKER_STEP_DEADLINE_SECONDS = 20

# When True (default), an artefact's content-set similarity cache is refreshed
# automatically after each file/archive extraction completes, so "Similar
# Artefacts" appears without a manual `flask rebuild-similarity`.  Set False to
# refresh only via the CLI command (e.g. on very large collections).
#SIMILARITY_AUTO_REFRESH = True

# When True, similarity scores are rarity-weighted (IDF): files common across
# many artefacts contribute less, so shared boilerplate inflates scores less.
# Off by default; changing it requires a full `flask rebuild-similarity`.
#SIMILARITY_USE_IDF = False

# Priority assigned to analyses queued via the web UI (uploads, re-analyse
# button).  Workers pick up jobs in order of priority DESC, created_at ASC.
# Default 10 (ANALYSIS_PRIORITY_HIGH) keeps interactive web uploads ahead
# of bulk API/CLI submissions.  Set to 0 to revert to a shared FIFO queue.
#WEB_UI_ANALYSIS_PRIORITY = 10

# =============================================================================
# Task runner (`flask taskrunner`)
# =============================================================================
# The task runner is a single-instance, worker-style poll loop (intended for its
# own container) that runs the DB-only control-plane analyses — HASH_RESCAN,
# PRODUCT_RECOGNITION, and the HASHDB_LINK / HASHDB_DELETE / HASHDB_RECOGNITION
# hash-database jobs — in-process with direct database access (no HTTP round
# trips to the web API).  Do NOT run more than one instance: the atomic job
# claim is concurrency-safe, but the periodic tasks below assume a single runner.
#
# Idle poll backoff: the loop sleeps between polls when no job is waiting,
# doubling the delay from the floor up to the ceiling; a claimed job resets it.
#TASKRUNNER_POLL_BACKOFF_FLOOR = 0.5
#TASKRUNNER_POLL_BACKOFF_CEILING = 10
#
# Periodic (time-based) maintenance intervals, in seconds.  Set any to 0 to
# disable that task.
#   - stale-reset: re-queue RUNNING analyses orphaned by a crash (same gate as
#     STALE_JOB_TIMEOUT_SECONDS); the analysis worker also does this for its own
#     jobs, so this mainly covers control-plane jobs.
#   - chunk GC: purge stale chunked-upload temp directories (requires the chunk
#     volume / CHUNK_DIR to be mounted into the task runner container).
#   - similarity rebuild: run a full `rebuild-similarity` on a schedule.  Heavy
#     on large collections and disabled by default (0) — opt in explicitly.
#TASKRUNNER_STALE_RESET_INTERVAL = 300
#TASKRUNNER_CHUNK_GC_INTERVAL = 3600
#TASKRUNNER_SIMILARITY_INTERVAL = 0
#
# Per-statement PostgreSQL statement_timeout (seconds) for the product-recognition
# scan, as a backstop against a single runaway query (a product whose required
# file hash is ubiquitous and seeds a huge candidate-folder scan).  When it fires
# the runner isolates and SKIPS that one product rather than failing the whole
# database's backfill.  Must stay well below STALE_JOB_TIMEOUT_SECONDS (default
# 3600) so a job legitimately mid-statement is not reset as stale.  0 disables;
# PostgreSQL-only (no-op on SQLite).
#TASKRUNNER_RECOGNITION_STATEMENT_TIMEOUT = 300

# =============================================================================
# Content Security Policy
# =============================================================================
# The app sets a CSP header on every response.  All CSS, JS, and fonts are
# served locally so no external CDN origins are needed by default.
# Override CSP_HEADER to customise it; set it to "" to disable (e.g. when
# the reverse proxy sets the header instead — but do not set it in both places,
# as browsers apply multiple CSP headers as a logical AND which is usually
# more restrictive than intended).
#
#CSP_HEADER = (
#    "default-src 'self'; "
#    "style-src 'self' 'unsafe-inline'; "
#    "script-src 'self' 'unsafe-inline'; "
#    "font-src 'self'; "
#    "img-src 'self' data:; "
#    "connect-src 'self'; "
#    "object-src 'none'; "
#    "frame-ancestors 'none'"
#)

# =============================================================================
# SSO / OpenID Connect (OAuth 2.0)
# Supports Keycloak, Okta, Azure AD, and any OIDC-compliant provider.
# =============================================================================

# Set to True to enable SSO login.
#OIDC_ENABLED = False

# Set to False to disable the local username/password login form.
# Leave True during migration; set False once all users are on SSO.
#LOCAL_LOGIN_ENABLED = True

# Label shown on the SSO login button: "Sign in with <name>"
#OIDC_PROVIDER_NAME = "Keycloak"

# Provider discovery URL (the .well-known/openid-configuration endpoint).
# Keycloak example: https://keycloak.example.com/realms/myrealm/.well-known/openid-configuration
#OIDC_DISCOVERY_URL = ""

# OAuth 2.0 client credentials (from the provider's client configuration).
#OIDC_CLIENT_ID = "arcology"
#OIDC_CLIENT_SECRET = ""

# Scopes to request (space-separated).  Default covers the claims Arcology needs.
#OIDC_SCOPES = "openid profile email"

# Which OIDC claim to use when linking a first-time SSO login to an existing
# local account.  Options: "preferred_username" (default), "email", "sub".
# After linking, future logins always match by the stored subject (sub).
#OIDC_MATCH_CLAIM = "preferred_username"

# Keycloak realm/client role names that map to Arcology permission levels.
# Roles are read from realm_access.roles, resource_access.<client_id>.roles,
# the top-level "roles" claim, and the "groups" claim (for Azure AD / Okta).
# Highest matching role wins (admin > read_write > read_only).
#OIDC_ROLE_ADMIN      = "arcology-admin"
#OIDC_ROLE_READ_WRITE = "arcology-read-write"
#OIDC_ROLE_READ_ONLY  = "arcology-read-only"
#OIDC_ROLE_API_ACCESS = "arcology-api"

# When True, users with no matching permission role are denied login entirely.
# When False (default), they are downgraded to READ_ONLY instead.
# Set True if removing all Arcology roles in the IdP should fully block access.
#OIDC_REQUIRE_ROLE = False

# How often (in seconds) to re-check the user's roles from the IdP userinfo endpoint
# while they are logged in.  0 (default) disables background sync — permissions only
# update at login time.  Requires the IdP to include role claims in the userinfo
# response (see Keycloak setup: "Add to userinfo" on the realm-role mapper).
#OIDC_SYNC_INTERVAL = 0

# When True (default), visiting /login with LOCAL_LOGIN_ENABLED = False automatically
# redirects to the SSO provider, skipping the login page — unless there is a pending
# flash message to display (e.g. "You have been logged out").  Set False to always
# show the login page with the SSO button rather than bouncing straight to the provider.
#OIDC_AUTO_REDIRECT = True

# Session lifetime for SSO logins (seconds).  Uses Flask's PERMANENT_SESSION_LIFETIME.
# Default: 28800 (8 hours).  Set this in your deployment config as needed.
#PERMANENT_SESSION_LIFETIME = 28800

# Enable when the identity provider realm is dedicated to Arcology (not shared with
# other applications).  When True, both the Logout button and access-denial redirects
# terminate the provider session via OIDC RP-Initiated Logout.
# Leave False for shared corporate SSO realms.
#OIDC_SINGLE_LOGOUT = False

# Sync group membership from the IdP on every login.  When True, the claim
# named by OIDC_GROUP_SYNC_CLAIM is read and used to add/remove the user from
# Arcology Groups (source='oidc').  Manually-assigned local group memberships
# are preserved.  Groups are auto-created the first time a claim value appears.
#
# IMPORTANT — disabling this setting stops future syncs but does NOT remove
# existing group memberships or delete groups that were created by a previous
# sync run.  To clean up after disabling, delete groups manually in the admin UI.
#OIDC_GROUP_SYNC_ENABLED = False
#OIDC_GROUP_SYNC_CLAIM = "groups"
#
# When a local group has the same name as an incoming IdP claim, Arcology
# can "link" it (convert it to IdP-managed), mirroring how local user accounts
# are linked on first SSO login.  Set OIDC_GROUP_LINK_LOCAL = False to refuse
# the link; the collision is logged at WARNING level and the user is not added
# to that group.  Existing shares on the local group are always preserved.
#OIDC_GROUP_LINK_LOCAL = True

# Storage backend: 'local' (default) or 's3'
# Local mode uses the filesystem (UPLOAD_FOLDER/OUTPUT_FOLDER above).
# S3 mode enables distributed workers on separate machines.
# See docker-compose.s3.yml for a full example with Garage.
#STORAGE_BACKEND = "local"

# S3-compatible storage settings (only used when STORAGE_BACKEND = 's3')
# Works with Garage, SeaweedFS, AWS S3, or any S3-compatible service.
#S3_ENDPOINT_URL = "http://garage:3900"
#S3_BUCKET = "arcology"
#S3_ACCESS_KEY = ""
#S3_SECRET_KEY = ""
#S3_REGION = "garage"
#S3_PUBLIC_URL = "http://localhost:3900"  # Browser-reachable URL for presigned links
