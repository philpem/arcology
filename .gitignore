syntax: glob

# text editor temporary files
*.bak
*~
.*.sw?

# mercurial "original" files (generated by 'revert' operations)
*.orig

# compiled python code
*.pyc

# python virtual environment
venv/*

# Apache configuration files
.htaccess
.htpasswd

# Application configuration
*.cfg
.env

# Data directory
data

# Flask instance folder (local config, temp DBs)
instance/

# Claude Code
.claude/
