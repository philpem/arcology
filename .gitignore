syntax: glob

# text editor temporary files
*.bak
*~
.*.sw?

# mercurial "original" files (generated by 'revert' operations)
*.orig

# compiled python code
*.pyc

# setuptools build artifacts
*.egg-info/

# python virtual environment
venv/*

# Apache configuration files
.htaccess
.htpasswd

# Application configuration
*.cfg
.env

# Data directory
data

# Flask instance folder (local config, temp DBs)
instance/

# Claude Code
.claude/

# Swagger UI static assets (downloaded at Docker build time or via
# devtools/fetch_swagger_ui.sh for local dev — not committed to the repo)
myapp/static/swagger-ui/
